FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Tên database nằm trong URI (kết nối thẳng tới DB/collections)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/codung?retryWrites=true&w=majority
# MONGODB_DB=codung  # Tùy chọn — nếu bỏ trống sẽ lấy từ MONGODB_URI

# Cloudinary — dùng URL đầy đủ
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_FOLDER_PREFIX=codung

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=nguyendung.c3hht@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=nguyendung.c3hht@gmail.com

OPENAI_API_KEY=your-openai-api-key

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Giới hạn upload (MB) — video bài học, mặc định 200
MAX_UPLOAD_MB=200
